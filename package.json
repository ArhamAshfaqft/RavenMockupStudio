{
  "name": "raven-mockup-studio",
  "version": "1.0.2",
  "description": "Raven Mockup Studio - Professional Offline Mockup Generator with Realistic Fabric Warping",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "cloud": "node tools/cloud-manager/server.js",
    "build": "electron-builder",
    "build:win": "npm run obfuscate && electron-builder --win",
    "build:mac": "npm run obfuscate && electron-builder --mac",
    "obfuscate": "node tools/obfuscate.js"
  },
  "build": {
    "appId": "com.ravenmock.studio",
    "productName": "Raven Mockup Studio",
    "extraMetadata": {
      "main": "build-src/main/main.js"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "build-src/**/*",
      "node_modules/**/*"
    ],
    "extraFiles": [
      {
        "from": "Library",
        "to": "Library",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "nsis-web"
      ],
      "icon": "assets/icon_safe.png",
      "executableName": "RMS"
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "appPackageUrl": "https://github.com/ArhamAshfaqft/RavenMockupStudio/releases/download/v${version}/",
      "artifactName": "RMS-Web-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "RMS-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ArhamAshfaqft",
        "repo": "RavenMockupStudio"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArhamAshfaqft/RavenMockupStudio.git"
  },
  "keywords": [
    "mockup",
    "bulk",
    "design",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^5.4.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "image-size": "^2.0.2",
    "pixi.js": "^7.3.2"
  }
}
